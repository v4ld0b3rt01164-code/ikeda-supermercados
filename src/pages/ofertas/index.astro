---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Ofertas | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Ofertas da Semana"
      title="Confira nossas promoções"
      subtitle="Arraste para o lado e confira o folheto completo"
    />

    <section class="py-16 md:py-20 px-6 md:px-12 bg-cream">
      <div class="max-w-7xl mx-auto">
        <div class="relative">
          <div class="absolute -inset-1.5 bg-gradient-to-br from-[var(--color-gold)]/30 to-[var(--color-navy)]/15 rounded-2xl blur-sm"></div>
          <div class="relative w-full rounded-2xl overflow-hidden shadow-xl bg-white" style="height: 75vh; min-height: 540px;">
            <iframe
              data-src="https://online.fliphtml5.com/ikedajunqueiradracena/kttj/"
              class="w-full h-full border-none lazy-iframe"
              allowfullscreen="true"
              seamless="seamless"
              scrolling="no"
              title="Folheto de Ofertas Ikeda"
            ></iframe>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<script is:inline>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const iframe = entry.target;
        iframe.src = iframe.dataset.src;
        observer.unobserve(iframe);
      }
    });
  }, { rootMargin: '200px' });

  document.querySelectorAll('.lazy-iframe').forEach(iframe => observer.observe(iframe));
</script>
