---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Ofertas | Ikeda Supermercados">
  <Navbar />
  <main class="pt-[120px] min-h-screen bg-bg">
    <section class="py-16 px-6 md:px-12 bg-gradient-to-br from-primary via-blue-600 to-blue-800">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-sm font-bold text-secondary uppercase tracking-[3px] mb-4 block reveal">Ofertas da Semana</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 reveal delay-100">Confira nossas promoções</h1>
        <p class="text-lg text-blue-100 max-w-2xl mx-auto reveal delay-200">Arraste para o lado e confira o folheto completo!</p>
      </div>
    </section>
    <section class="py-16 px-6 md:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="w-full rounded-2xl overflow-hidden card-highlighted reveal-scale" style="height: 75vh; min-height: 600px;">
          <iframe 
            src="https://online.fliphtml5.com/ikedajunqueiradracena/kttj/" 
            class="w-full h-full border-none"
            allowfullscreen="true"
            seamless="seamless"
            scrolling="no"
            title="Folheto de Ofertas Ikeda"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
