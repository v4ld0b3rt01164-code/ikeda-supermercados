---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import { lojas } from '../../data/lojas';
---

<Layout title="Nossas Lojas | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Nossas Lojas"
      title="Onde nos encontrar"
      subtitle="Encontre a Ikeda mais perto de você"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
        {lojas.map((loja, index) => (
          <article class="card card-hover p-8 md:p-10" style={`animation-delay: ${index * 120}ms`}>
            <div class="flex items-center gap-4 mb-7 pb-6 border-b border-slate-100">
              <span class="flex items-center justify-center w-12 h-12 rounded-full bg-[var(--color-navy)]/5 text-[var(--color-navy)] flex-shrink-0">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2H5a2 2 0 00-2 2zm0 0V7a2 2 0 012-2h12"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M8 21v-5a4 4 0 018 0v5"/></svg>
              </span>
              <h2 class="text-2xl md:text-3xl font-extrabold text-[var(--color-navy)]">{loja.nome}</h2>
            </div>
            <div class="space-y-4 mb-8">
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-[var(--color-gold)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><circle cx="12" cy="11" r="2.5" stroke-width="1.6"/></svg>
                <span class="text-[var(--color-muted)]">{loja.endereco}</span>
              </div>
              <div class="flex items-center gap-3">
                <svg class="w-5 h-5 text-[var(--color-gold)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <span class="text-[var(--color-muted)]">{loja.telefone}</span>
              </div>
              <div class="flex items-start gap-3">
                <svg class="w-5 h-5 mt-0.5 text-[var(--color-gold)] flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="1.6"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M12 7v5l3 2"/></svg>
                <div class="text-[var(--color-muted)]">
                  {loja.horarios.map((h) => <div>{h}</div>)}
                </div>
              </div>
            </div>
            <a href={loja.mapa} target="_blank" rel="noopener noreferrer" class="btn-outline-dark">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
              Como Chegar
            </a>
          </article>
        ))}
      </div>
    </section>
  </main>
  <Footer />
</Layout>
