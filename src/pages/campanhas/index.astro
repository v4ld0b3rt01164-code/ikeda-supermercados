---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const campanhas = [
  {
    id: "vinho-crevelim",
    nome: "Promoção Vinho Crevelim",
    imagem: "https://ikedasupermercados.com.br/uploads/20241230175027_ikeda-dracena---promocao-crevelim---banner-site.jpg",
    status: "finalizada"
  },
  {
    id: "super-coffee",
    nome: "Promoção Super Coffee",
    imagem: "https://ikedasupermercados.com.br/uploads/20241126193901_ikeda-dracena-promocao-super-coffe-post.jpg",
    status: "finalizada"
  },
  {
    id: "caminhao-de-premios",
    nome: "Promoção Caminhão de Prêmios",
    imagem: "https://ikedasupermercados.com.br/uploads/20180622154537_banner-site.png",
    status: "finalizada"
  },
  {
    id: "toda-mae-merece",
    nome: "Toda Mãe Merece Ikeda Supermercados",
    imagem: "https://ikedasupermercados.com.br/uploads/20180419202635_banner-site.png",
    status: "finalizada"
  }
];
---

<Layout title="Campanhas | Ikeda Supermercados">
  <Navbar />
  <main class="pt-[120px] min-h-screen bg-bg">
    <section class="py-16 px-6 md:px-12 bg-gradient-to-br from-primary via-blue-600 to-blue-800">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-sm font-bold text-secondary uppercase tracking-[3px] mb-4 block reveal">Campanhas</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 reveal delay-100">Nossas Campanhas</h1>
        <p class="text-lg text-blue-100 max-w-2xl mx-auto reveal delay-200">Confira nossas campanhas e promoções especiais</p>
      </div>
    </section>
    <section class="py-16 px-6 md:px-12">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {campanhas.map((campanha, index) => (
            <div class="card-highlighted overflow-hidden" style={`animation-delay: ${index * 150}ms`}>
              <div class="h-64 overflow-hidden relative">
                <img 
                  src={campanha.imagem} 
                  alt={campanha.nome} 
                  class="w-full h-full object-cover transition-transform duration-500 hover:scale-110"
                />
                <div class="absolute top-4 right-4 px-4 py-2 bg-red-500 text-white text-xs font-bold rounded-full shadow-lg">
                  Campanha Finalizada
                </div>
              </div>
              <div class="p-6">
                <h3 class="text-xl font-bold text-text">{campanha.nome}</h3>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
