---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';

const campanhas = [
  {
    id: "vinho-crevelim",
    nome: "Promoção Vinho Crevelim",
    imagem: "https://ikedasupermercados.com.br/uploads/20241230175027_ikeda-dracena---promocao-crevelim---banner-site.jpg",
    status: "finalizada"
  },
  {
    id: "super-coffee",
    nome: "Promoção Super Coffee",
    imagem: "https://ikedasupermercados.com.br/uploads/20241126193901_ikeda-dracena-promocao-super-coffe-post.jpg",
    status: "finalizada"
  },
  {
    id: "caminhao-de-premios",
    nome: "Promoção Caminhão de Prêmios",
    imagem: "https://ikedasupermercados.com.br/uploads/20180622154537_banner-site.png",
    status: "finalizada"
  },
  {
    id: "toda-mae-merece",
    nome: "Toda Mãe Merece Ikeda Supermercados",
    imagem: "https://ikedasupermercados.com.br/uploads/20180419202635_banner-site.png",
    status: "finalizada"
  }
];
---

<Layout title="Campanhas | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Campanhas"
      title="Nossas Campanhas"
      subtitle="Confira nossas campanhas e promoções especiais"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-7xl mx-auto">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {campanhas.map((campanha, index) => (
            <article class="card overflow-hidden reveal" style={`animation-delay: ${index * 100}ms`}>
              <div class="relative bg-slate-50">
                <img src={campanha.imagem} alt={campanha.nome} class="w-full h-auto object-contain" />
                <span class="absolute top-4 right-4 px-3 py-1.5 bg-[var(--color-navy)]/85 backdrop-blur text-white text-xs font-semibold rounded-full tracking-wide">
                  Finalizada
                </span>
              </div>
              <div class="p-6 border-t border-slate-100">
                <span class="eyebrow text-[10px]">Campanha</span>
                <h3 class="text-lg font-bold text-[var(--color-navy)] mt-1.5">{campanha.nome}</h3>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
