---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';

const receitas = [
  {
    id: "torta-holandesa-com-nata",
    nome: "Torta Holandesa com Nata",
    imagem: "/images/receitas/torta-holandesa.jpg",
    ingredientes: `Para o Creme:
- 400g de nata
- 1 lata de leite condensado
- 1 caixinha de creme de leite

Para a Montagem:
- 1 copo de leite
- 1 cálice de conhaque (opcional)
- 1 pacote de bolacha Calypso ou Tortinhas
- 1 pacote de bolacha maisena

Para a Cobertura:
- 1 caixinha de creme de leite
- 150g de chocolate ao leite`,
    modoPreparo: "Na batedeira, bata a nata em velocidade média até obter um creme fofo. Adicione o leite condensado e o creme de leite, misture bem. Em um refratário, faça uma camada de bolachas embebidas no leite com conhaque. Cubra com o creme. Repita as camadas até acabar os ingredientes. Para a cobertura, derreta o chocolate com o creme de leite e despeje por cima. Leve à geladeira por pelo menos 4 horas."
  },
  {
    id: "salpicao",
    nome: "Salpicão",
    imagem: "/images/receitas/salpicao.jpg",
    ingredientes: `- 300g de frango cozido e desfiado
- 100g de presunto cortado em palitos
- 150g de muçarela cortada em palitos
- 1 cenoura grande cortada em palitos
- 2 batatas médias descascadas e cortadas em palitos
- 1 caixinha de creme de leite
- 200g de maionese
- 1 fio de azeite
- ½ cebola roxa cortada em meia-lua
- ½ lata de milho-verde
- ½ lata de ervilha
- ½ pimentão verde cortado em cubos`,
    modoPreparo: "Em uma tigela grande, misture o frango desfiado com a maionese e o creme de leite. Adicione o presunto, a muçarela, a cenoura e as batatas. Acrescente o milho, a ervilha e o pimentão. Tempere com azeite, sal e pimenta a gosto. Misture tudo delicadamente. Leve à geladeira por pelo menos 2 horas antes de servir."
  },
  {
    id: "bolo-de-pessego",
    nome: "Bolo de Pêssego",
    imagem: "/images/receitas/bolo-pessego.jpg",
    ingredientes: `- 1 3/4 chávenas de açúcar
- 4 pêssegos descascados, sem caroço e cortados em 6 partes
- 250g de manteiga sem sal e derretida
- 1 colher de chá de extrato de baunilha
- 225g de farinha de trigo
- 3 colheres de chá de fermento
- 60g de amêndoas
- 6 ovos
- 1/2 chávena de água
- 1/2 colher de chá de sal`,
    modoPreparo: "Pré-aqueça o forno a 180º C. Unte uma forma redonda com manteiga e polvilhe farinha. Em uma tigela, bata os ovos com o açúcar até obter uma mistura fofa. Adicione a manteiga derretida, a baunilha e a água. Misture a farinha de trigo, o fermento e o sal. Despeje na forma e distribua os pedaços de pêssego por cima. Asse por aproximadamente 40 minutos ou até que um palito inserido no centro saia limpo."
  },
  {
    id: "bolo-de-limao-com-yogurte",
    nome: "Bolo de Limão com Yogurte",
    imagem: "/images/receitas/bolo-limao.jpg",
    ingredientes: `MASSA:
- 4 ovos
- 1 xícara (chá) de iogurte natural
- 1 e 1/2 xícara (chá) de açúcar
- 2 colheres (sopa) de raspas de limão
- Suco de 1 limão
- 1/2 xícara de óleo (de preferência de canola)
- 2 xícaras de (chá) de farinha de trigo peneirada
- 1 colher (sopa) de fermento em pó`,
    modoPreparo: "Em um liquidificador, bata os ovos, o iogurte, o açúcar, as raspas de limão, o suco de limão e o óleo. Transfira para uma tigela e adicione a farinha de trigo peneirada e o fermento, mexendo delicadamente. Despeje em uma forma untada e enfarinhada. Asse em forno pré-aquecido a 180ºC por cerca de 35 a 40 minutos, ou até que um palito inserido no centro saia limpo."
  }
];
---

<Layout title="Receitas | Ikeda Supermercados">
  <Navbar />

  <main class="min-h-screen">
    <PageHero
      eyebrow="Receitas"
      title="Inspirações Culinárias"
      subtitle="Receitas deliciosas com ingredientes frescos da Ikeda"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-7xl mx-auto space-y-10">
        {receitas.map((receita, index) => (
          <article class="card overflow-hidden reveal" style={`animation-delay: ${index * 100}ms`}>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-0">
              <div class="lg:col-span-1 h-64 lg:h-auto overflow-hidden">
                <img src={receita.imagem} alt={receita.nome} class="w-full h-full object-cover" loading="lazy" decoding="async" />
              </div>

              <div class="lg:col-span-2 p-7 md:p-10">
                <span class="eyebrow text-[10px]">Receita</span>
                <h2 class="text-2xl md:text-3xl font-extrabold text-[var(--color-navy)] mt-2 mb-6">
                  {receita.nome}
                </h2>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <h3 class="text-xs font-bold text-[var(--color-gold)] uppercase tracking-[0.2em] mb-3">
                      Ingredientes
                    </h3>
                    <div class="text-sm text-[var(--color-muted)] whitespace-pre-line leading-relaxed bg-cream rounded-xl p-4 border border-slate-100">
                      {receita.ingredientes}
                    </div>
                  </div>

                  <div>
                    <h3 class="text-xs font-bold text-[var(--color-gold)] uppercase tracking-[0.2em] mb-3">
                      Modo de Preparo
                    </h3>
                    <div class="text-sm text-[var(--color-muted)] leading-relaxed bg-cream rounded-xl p-4 border border-slate-100">
                      {receita.modoPreparo}
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
