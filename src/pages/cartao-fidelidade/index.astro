---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';

const beneficios = [
  { titulo: "Prêmios Exclusivos", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/>` },
  { titulo: "Descontos Especiais", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>` },
  { titulo: "Pontos a Cada Compra", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>` },
  { titulo: "Acesso Fácil", icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>` }
];
---

<Layout title="Cartão Fidelidade | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Cartão Fidelidade"
      title="Acumule pontos e ganhe prêmios"
      subtitle="Cadastre-se e comece a acumular benefícios"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-4xl mx-auto">
        <!-- O que é -->
        <div class="card p-8 md:p-12 mb-10 reveal">
          <span class="eyebrow">O que é?</span>
          <h2 class="heading-display text-2xl md:text-3xl text-[var(--color-navy)] mt-2 mb-5">
            Benefícios que vão além das ofertas
          </h2>
          <div class="divider-gold mb-6"></div>
          <p class="text-[var(--color-muted)] leading-relaxed mb-4">
            O nosso Cartão Fidelidade proporciona descontos que vão além das nossas ofertas diárias. Com o seu CPF em mãos e 5 minutinhos vagos, você preenche o cadastro de requerimento e em apenas 5 dias úteis, poderá pagar menos em suas compras com nossos descontos exclusivos.
          </p>
          <p class="text-[var(--color-muted)] leading-relaxed mb-8">
            Tanto pessoas físicas, quanto jurídicas podem adquiri-lo, desde que tenham 16 anos completos. Garanta seus descontos e boas compras!
          </p>

          <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
            {beneficios.map((b) => (
              <div class="text-center p-5 rounded-xl bg-white border border-slate-100">
                <span class="inline-flex items-center justify-center w-11 h-11 rounded-full bg-[var(--color-gold)]/15 text-[var(--color-gold)] mb-3">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={b.icon} />
                </span>
                <span class="text-sm font-semibold text-[var(--color-navy)] block leading-snug">{b.titulo}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Form -->
        <div class="card p-8 md:p-12 reveal">
          <span class="eyebrow">Solicitar Cartão</span>
          <h2 class="heading-display text-2xl md:text-3xl text-[var(--color-navy)] mt-2 mb-8">
            Preencha seus dados
          </h2>

          <form class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="field-label">Nome Completo *</label>
                <input type="text" class="field-input" placeholder="Nome Completo" required />
              </div>
              <div>
                <label class="field-label">Loja de Retirada *</label>
                <select class="field-select" required>
                  <option value="">Selecione a Loja</option>
                  <option value="dracena">Dracena/SP - Centro</option>
                  <option value="junqueiropolis">Junqueirópolis/SP - Centro</option>
                </select>
              </div>
              <div>
                <label class="field-label">CPF *</label>
                <input type="text" class="field-input" placeholder="000.000.000-00" required />
              </div>
              <div>
                <label class="field-label">RG</label>
                <input type="text" class="field-input" placeholder="RG" />
              </div>
              <div>
                <label class="field-label">Data de Expedição do RG *</label>
                <input type="text" class="field-input" placeholder="00/00/0000" required />
              </div>
              <div>
                <label class="field-label">Sexo *</label>
                <select class="field-select" required>
                  <option value="">Escolha</option>
                  <option value="M">Masculino</option>
                  <option value="F">Feminino</option>
                </select>
              </div>
              <div>
                <label class="field-label">Data de Nascimento *</label>
                <input type="text" class="field-input" placeholder="00/00/0000" required />
              </div>
              <div>
                <label class="field-label">Estado Civil *</label>
                <select class="field-select" required>
                  <option value="Solteiro(a)">Solteiro(a)</option>
                  <option value="Casado(a)">Casado(a)</option>
                  <option value="Divorciado(a)">Divorciado(a)</option>
                </select>
              </div>
              <div>
                <label class="field-label">E-mail *</label>
                <input type="email" class="field-input" placeholder="seu@email.com" required />
              </div>
              <div>
                <label class="field-label">CEP *</label>
                <input type="text" class="field-input" placeholder="00000-000" required />
              </div>
              <div>
                <label class="field-label">Cidade *</label>
                <input type="text" class="field-input" placeholder="Cidade" required />
              </div>
              <div>
                <label class="field-label">Bairro *</label>
                <input type="text" class="field-input" placeholder="Bairro" required />
              </div>
              <div>
                <label class="field-label">Endereço *</label>
                <input type="text" class="field-input" placeholder="Endereço" required />
              </div>
              <div>
                <label class="field-label">Número</label>
                <input type="text" class="field-input" placeholder="Nº" />
              </div>
              <div>
                <label class="field-label">Complemento *</label>
                <input type="text" class="field-input" placeholder="Complemento" required />
              </div>
              <div>
                <label class="field-label">Estado *</label>
                <select class="field-select" required>
                  <option value="">Selecione seu Estado</option>
                  <option value="SP">São Paulo</option>
                  <option value="MS">Mato Grosso do Sul</option>
                </select>
              </div>
              <div>
                <label class="field-label">Telefone *</label>
                <input type="tel" class="field-input" placeholder="(00) 0000-0000" required />
              </div>
              <div>
                <label class="field-label">Celular *</label>
                <input type="tel" class="field-input" placeholder="(00) 00000-0000" required />
              </div>
            </div>

            <div class="pt-2">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-5 h-5 accent-[var(--color-navy)]" required />
                <span class="text-sm text-[var(--color-muted)]">Li e aceito os termos de adesão ao Cartão Fidelidade Ikeda Supermercados *</span>
              </label>
            </div>
            <button type="submit" class="btn-primary w-full">Cadastrar Cartão</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
