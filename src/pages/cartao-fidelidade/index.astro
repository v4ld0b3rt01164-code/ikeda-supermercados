---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Cartão Fidelidade | Ikeda Supermercados">
  <Navbar />
  <main class="pt-[120px] min-h-screen bg-bg">
    <section class="py-16 px-6 md:px-12 bg-gradient-to-br from-secondary via-yellow-400 to-yellow-500">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-sm font-bold text-primary uppercase tracking-[3px] mb-4 block reveal">Cartão Fidelidade</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text mb-4 reveal delay-100">Acumule pontos e ganhe prêmios</h1>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto reveal delay-200">Cadastre-se e comece a acumular benefícios</p>
      </div>
    </section>
    <section class="py-16 px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="card-highlighted p-8 md:p-12 mb-12 reveal">
          <h2 class="text-2xl font-bold text-primary mb-4">O que é?</h2>
          <p class="text-gray-600 leading-relaxed mb-6">
            O nosso Cartão Fidelidade proporciona descontos que vão além das nossas ofertas diárias. Com o seu CPF em mãos e 5 minutinhos vagos, você preenche o cadastro de requerimento e em apenas 5 dias úteis, poderá pagar menos em suas compras com nossos descontos exclusivos.
          </p>
          <p class="text-gray-600 leading-relaxed mb-6">
            Tanto pessoas físicas, quanto jurídicas podem adquiri-lo, desde que tenham 16 anos completos. Garanta seus descontos e boas compras!
          </p>
          <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-surface rounded-xl p-4 text-center">
              <span class="text-3xl block mb-2">🎁</span>
              <span class="text-sm font-medium text-text">Prêmios Exclusivos</span>
            </div>
            <div class="bg-surface rounded-xl p-4 text-center">
              <span class="text-3xl block mb-2">💰</span>
              <span class="text-sm font-medium text-text">Descontos Especiais</span>
            </div>
            <div class="bg-surface rounded-xl p-4 text-center">
              <span class="text-3xl block mb-2">⭐</span>
              <span class="text-sm font-medium text-text">Pontos a Cada Compra</span>
            </div>
            <div class="bg-surface rounded-xl p-4 text-center">
              <span class="text-3xl block mb-2">📱</span>
              <span class="text-sm font-medium text-text">Acesso Fácil</span>
            </div>
          </div>
        </div>
        <div class="card-highlighted p-8 md:p-12 reveal">
          <h2 class="text-2xl font-bold text-primary mb-6">Solicitar Cartão</h2>
          <form class="space-y-5">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Nome Completo *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Nome Completo" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Loja de Retirada *</label>
                <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                  <option value="">Selecione a Loja</option>
                  <option value="dracena">Dracena/SP - Centro</option>
                  <option value="junqueiropolis">Junqueirópolis/SP - Centro</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">CPF *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="000.000.000-00" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">RG</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="RG" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Data de Expedição do RG *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="00/00/0000" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Sexo *</label>
                <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                  <option value="">Escolha</option>
                  <option value="M">Masculino</option>
                  <option value="F">Feminino</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Data de Nascimento *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="00/00/0000" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Estado Civil *</label>
                <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                  <option value="Solteiro(a)">Solteiro(a)</option>
                  <option value="Casado(a)">Casado(a)</option>
                  <option value="Divorciado(a)">Divorciado(a)</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">E-mail *</label>
                <input type="email" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="seu@email.com" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">CEP *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="00000-000" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Cidade *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Cidade" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Bairro *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Bairro" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Endereço *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Endereço" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Número</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Nº" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Complemento *</label>
                <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Complemento" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Estado *</label>
                <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                  <option value="">Selecione seu Estado</option>
                  <option value="SP">São Paulo</option>
                  <option value="MS">Mato Grosso do Sul</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Telefone *</label>
                <input type="tel" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="(00) 0000-0000" required />
              </div>
              <div>
                <label class="block text-sm font-semibold text-text mb-2">Celular *</label>
                <input type="tel" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="(00) 00000-0000" required />
              </div>
            </div>
            <div class="mt-6">
              <label class="flex items-start gap-3 cursor-pointer">
                <input type="checkbox" class="mt-1 w-5 h-5 accent-primary" required />
                <span class="text-sm text-gray-600">Li e aceito os termos de adesão ao Cartão Fidelidade Ikeda Supermercados *</span>
              </label>
            </div>
            <button type="submit" class="w-full btn-primary text-base">✨ Cadastrar Cartão</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
