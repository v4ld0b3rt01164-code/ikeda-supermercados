---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';

const contatos = [
  { loja: "Junqueirópolis", telefone: "(18) 3841-1326", endereco: "Rua Rui Barbosa, 481" },
  { loja: "Dracena", telefone: "(18) 3822-3272", endereco: "Rua Messias Ferreira da Palma, 266" }
];
---

<Layout title="Contato | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Contato"
      title="Fale Conosco"
      subtitle="Responderemos assim que possível!"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-5 gap-8">
        <!-- Info -->
        <div class="lg:col-span-2 space-y-6">
          <div class="card p-6 md:p-7 reveal">
            <span class="eyebrow">Atendimento</span>
            <h2 class="heading-display text-xl text-[var(--color-navy)] mt-2 mb-4">Nossos telefones</h2>
            <div class="divider-gold mb-5"></div>
            <div class="space-y-4">
              {contatos.map((c) => (
                <div>
                  <span class="block text-sm font-bold text-[var(--color-navy)]">{c.loja}</span>
                  <span class="text-sm text-[var(--color-muted)]">{c.endereco}</span>
                  <a href={`tel:+55${c.telefone.replace(/\D/g, '')}`} class="flex items-center gap-2 mt-1 text-[var(--color-muted)] hover:text-[var(--color-gold)] transition-colors">
                    <svg class="w-4 h-4 text-[var(--color-gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                    <span class="text-sm">{c.telefone}</span>
                  </a>
                </div>
              ))}
            </div>
          </div>

          <div class="card p-6 md:p-7 reveal delay-100">
            <span class="eyebrow">WhatsApp</span>
            <h2 class="heading-display text-xl text-[var(--color-navy)] mt-2 mb-4">Fale agora</h2>
            <div class="divider-gold mb-5"></div>
            <p class="text-sm text-[var(--color-muted)] mb-4">Prefere conversar pelo WhatsApp? Estamos prontos para ajudar.</p>
            <a href="https://wa.me/5518997374186" target="_blank" rel="noopener noreferrer" class="btn-primary w-full">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Chamar no WhatsApp
            </a>
          </div>
        </div>

        <!-- Form -->
        <div class="lg:col-span-3">
          <div class="card p-8 md:p-10 reveal">
            <span class="eyebrow">Deixe sua mensagem</span>
            <h2 class="heading-display text-2xl md:text-3xl text-[var(--color-navy)] mt-2 mb-6">Envie sua mensagem</h2>
            <div class="divider-gold mb-8"></div>

            <form class="space-y-5">
              <div>
                <label class="field-label">Selecione a Loja *</label>
                <select class="field-select" required>
                  <option value="">Selecione a Loja</option>
                  <option value="junqueiropolis">Comercial Ikeda Ltda (Junqueirópolis) - Junqueirópolis/SP - Centro</option>
                  <option value="dracena">COMERCIAL IKEDA LTDA (Dracena) - Dracena/SP - Centro</option>
                </select>
              </div>
              <div>
                <label class="field-label">Nome Completo *</label>
                <input type="text" class="field-input" placeholder="Nome Completo" required />
              </div>
              <div>
                <label class="field-label">E-mail *</label>
                <input type="email" class="field-input" placeholder="seu@email.com" required />
              </div>
              <div>
                <label class="field-label">Telefone</label>
                <input type="tel" class="field-input" placeholder="(00) 0000-0000" />
              </div>
              <div>
                <label class="field-label">Mensagem *</label>
                <textarea class="field-textarea" rows="5" placeholder="Digite sua mensagem" required></textarea>
              </div>
              <button type="submit" class="btn-primary w-full">Enviar Mensagem</button>
            </form>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
