---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Contato | Ikeda Supermercados">
  <Navbar />
  <main class="pt-[120px] min-h-screen bg-bg">
    <section class="py-16 px-6 md:px-12 bg-gradient-to-br from-primary via-blue-600 to-blue-800">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-sm font-bold text-secondary uppercase tracking-[3px] mb-4 block reveal">Contato</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-4 reveal delay-100">Fale Conosco</h1>
        <p class="text-lg text-blue-100 max-w-2xl mx-auto reveal delay-200">Responderemos assim que possível!</p>
      </div>
    </section>
    <section class="py-16 px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="card-highlighted p-8 md:p-12 reveal">
          <h2 class="text-2xl font-bold text-text mb-6">Deixe sua mensagem</h2>
          <form class="space-y-5">
            <div>
              <label class="block text-sm font-semibold text-text mb-2">Selecione a Loja *</label>
              <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                <option value="">Selecione a Loja</option>
                <option value="junqueiropolis">Comercial Ikeda Ltda (Junqueirópolis) - Junqueirópolis/SP - Centro</option>
                <option value="dracena">COMERCIAL IKEDA LTDA (Dracena) - Dracena/SP - Centro</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-text mb-2">Nome Completo *</label>
              <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Nome Completo" required />
            </div>
            <div>
              <label class="block text-sm font-semibold text-text mb-2">E-mail *</label>
              <input type="email" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="seu@email.com" required />
            </div>
            <div>
              <label class="block text-sm font-semibold text-text mb-2">Telefone</label>
              <input type="tel" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="(00) 0000-0000" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-text mb-2">Mensagem *</label>
              <textarea class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors resize-y h-32" placeholder="Digite sua mensagem" required></textarea>
            </div>
            <button type="submit" class="w-full btn-primary text-base">📨 Enviar Mensagem</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
