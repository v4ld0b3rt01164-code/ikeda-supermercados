---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<Layout title="Trabalhe Conosco | Ikeda Supermercados">
  <Navbar />
  <main class="pt-[120px] min-h-screen bg-bg">
    <section class="py-16 px-6 md:px-12 bg-gradient-to-br from-secondary via-yellow-400 to-yellow-500">
      <div class="max-w-7xl mx-auto text-center">
        <span class="text-sm font-bold text-primary uppercase tracking-[3px] mb-4 block reveal">Trabalhe Conosco</span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-text mb-4 reveal delay-100">Envie seu currículo</h1>
        <p class="text-lg text-gray-700 max-w-2xl mx-auto reveal delay-200">Faça parte da nossa equipe</p>
      </div>
    </section>
    <section class="py-16 px-6 md:px-12">
      <div class="max-w-4xl mx-auto">
        <div class="card-highlighted p-8 md:p-12 reveal">
          <form class="space-y-8">
            <div>
              <h3 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
                <span class="text-2xl">👤</span> Dados Pessoais
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">CPF *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="000.000.000-00" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">RG *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="RG" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Nome Completo *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Nome Completo" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Data de Nascimento *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="00/00/0000" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Escolaridade *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="">Escolaridade</option>
                    <option value="nao-alfabetizado">Não Alfabetizado</option>
                    <option value="fundamental">1º Grau Completo (Fundamental)</option>
                    <option value="medio">2º Grau Completo (Ensino Médio)</option>
                    <option value="tecnico">Especialização (Cursos Técnicos, etc)</option>
                    <option value="superior">Ensino Superior Completo</option>
                    <option value="mestrado">Mestrado</option>
                    <option value="pos-doutorado">Pós-doutorado</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Portador de Deficiência *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="nao">Não Possuo Deficiência</option>
                    <option value="sim">Possuo algum tipo de deficiência</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Estado Civil *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="">Estado Civil</option>
                    <option value="Solteiro(a)">Solteiro(a)</option>
                    <option value="Casado(a)">Casado(a)</option>
                    <option value="Divorciado(a)">Divorciado(a)</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Disponibilidade de Horário *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="">Qual sua disponibilidade?</option>
                    <option value="Os dois turnos">Os dois turnos</option>
                    <option value="Manhã/Tarde">Manhã/Tarde</option>
                    <option value="Tarde/Noite">Tarde/Noite</option>
                  </select>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
                <span class="text-2xl">📍</span> Endereço
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">CEP *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="00000-000" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Estado *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="">Selecione seu Estado</option>
                    <option value="SP">São Paulo</option>
                    <option value="MS">Mato Grosso do Sul</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Cidade *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Cidade" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Bairro *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Bairro" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Endereço *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Endereço" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Número *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Nº" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Complemento</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Complemento" />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Telefone *</label>
                  <input type="tel" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="(00) 0000-0000" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">E-mail *</label>
                  <input type="email" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="seu@email.com" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Cidade Natal *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Cidade Natal" required />
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
                <span class="text-2xl">💼</span> Informações Profissionais
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Cargo de Interesse *</label>
                  <input type="text" class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" placeholder="Cargo que está se candidatando" required />
                </div>
                <div>
                  <label class="block text-sm font-semibold text-text mb-2">Loja *</label>
                  <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors" required>
                    <option value="">Selecione a Loja</option>
                    <option value="junqueiropolis">Junqueirópolis/SP - Centro - Loja 01</option>
                    <option value="dracena">Dracena/SP - Centro - Loja de Dracena</option>
                  </select>
                </div>
              </div>
            </div>

            <div>
              <h3 class="text-xl font-bold text-primary mb-4 flex items-center gap-2">
                <span class="text-2xl">📝</span> Fale Sobre Você
              </h3>
              <div>
                <textarea class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors resize-y h-24" placeholder="Conte um pouco sobre você..."></textarea>
              </div>
            </div>

            <button type="submit" class="w-full btn-primary text-base">📤 Enviar Currículo</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
