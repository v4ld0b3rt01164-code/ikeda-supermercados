---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
---

<Layout title="Trabalhe Conosco | Ikeda Supermercados">
  <Navbar />
  <main class="min-h-screen">
    <PageHero
      eyebrow="Trabalhe Conosco"
      title="Envie seu currículo"
      subtitle="Faça parte da nossa equipe"
    />

    <section class="py-20 md:py-24 px-6 md:px-12 bg-cream">
      <div class="max-w-4xl mx-auto">
        <div class="card p-8 md:p-12 reveal">
          <form class="space-y-10">
            <!-- Dados Pessoais -->
            <div>
              <span class="eyebrow">Dados Pessoais</span>
              <h3 class="heading-display text-xl md:text-2xl text-[var(--color-navy)] mt-2 mb-6">Informações pessoais</h3>
              <div class="divider-gold mb-6"></div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="field-label">CPF *</label>
                  <input type="text" class="field-input" placeholder="000.000.000-00" required />
                </div>
                <div>
                  <label class="field-label">RG *</label>
                  <input type="text" class="field-input" placeholder="RG" required />
                </div>
                <div>
                  <label class="field-label">Nome Completo *</label>
                  <input type="text" class="field-input" placeholder="Nome Completo" required />
                </div>
                <div>
                  <label class="field-label">Data de Nascimento *</label>
                  <input type="text" class="field-input" placeholder="00/00/0000" required />
                </div>
                <div>
                  <label class="field-label">Escolaridade *</label>
                  <select class="field-select" required>
                    <option value="">Escolaridade</option>
                    <option value="nao-alfabetizado">Não Alfabetizado</option>
                    <option value="fundamental">1º Grau Completo (Fundamental)</option>
                    <option value="medio">2º Grau Completo (Ensino Médio)</option>
                    <option value="tecnico">Especialização (Cursos Técnicos, etc)</option>
                    <option value="superior">Ensino Superior Completo</option>
                    <option value="mestrado">Mestrado</option>
                    <option value="pos-doutorado">Pós-doutorado</option>
                  </select>
                </div>
                <div>
                  <label class="field-label">Portador de Deficiência *</label>
                  <select class="field-select" required>
                    <option value="nao">Não Possuo Deficiência</option>
                    <option value="sim">Possuo algum tipo de deficiência</option>
                  </select>
                </div>
                <div>
                  <label class="field-label">Estado Civil *</label>
                  <select class="field-select" required>
                    <option value="">Estado Civil</option>
                    <option value="Solteiro(a)">Solteiro(a)</option>
                    <option value="Casado(a)">Casado(a)</option>
                    <option value="Divorciado(a)">Divorciado(a)</option>
                  </select>
                </div>
                <div>
                  <label class="field-label">Disponibilidade de Horário *</label>
                  <select class="field-select" required>
                    <option value="">Qual sua disponibilidade?</option>
                    <option value="Os dois turnos">Os dois turnos</option>
                    <option value="Manhã/Tarde">Manhã/Tarde</option>
                    <option value="Tarde/Noite">Tarde/Noite</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Endereço -->
            <div>
              <span class="eyebrow">Endereço</span>
              <h3 class="heading-display text-xl md:text-2xl text-[var(--color-navy)] mt-2 mb-6">Onde você mora</h3>
              <div class="divider-gold mb-6"></div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="field-label">CEP *</label>
                  <input type="text" class="field-input" placeholder="00000-000" required />
                </div>
                <div>
                  <label class="field-label">Estado *</label>
                  <select class="field-select" required>
                    <option value="">Selecione seu Estado</option>
                    <option value="SP">São Paulo</option>
                    <option value="MS">Mato Grosso do Sul</option>
                  </select>
                </div>
                <div>
                  <label class="field-label">Cidade *</label>
                  <input type="text" class="field-input" placeholder="Cidade" required />
                </div>
                <div>
                  <label class="field-label">Bairro *</label>
                  <input type="text" class="field-input" placeholder="Bairro" required />
                </div>
                <div>
                  <label class="field-label">Endereço *</label>
                  <input type="text" class="field-input" placeholder="Endereço" required />
                </div>
                <div>
                  <label class="field-label">Número *</label>
                  <input type="text" class="field-input" placeholder="Nº" required />
                </div>
                <div>
                  <label class="field-label">Complemento</label>
                  <input type="text" class="field-input" placeholder="Complemento" />
                </div>
                <div>
                  <label class="field-label">Telefone *</label>
                  <input type="tel" class="field-input" placeholder="(00) 0000-0000" required />
                </div>
                <div>
                  <label class="field-label">E-mail *</label>
                  <input type="email" class="field-input" placeholder="seu@email.com" required />
                </div>
                <div>
                  <label class="field-label">Cidade Natal *</label>
                  <input type="text" class="field-input" placeholder="Cidade Natal" required />
                </div>
              </div>
            </div>

            <!-- Informações Profissionais -->
            <div>
              <span class="eyebrow">Informações Profissionais</span>
              <h3 class="heading-display text-xl md:text-2xl text-[var(--color-navy)] mt-2 mb-6">Cargo desejado</h3>
              <div class="divider-gold mb-6"></div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                  <label class="field-label">Cargo de Interesse *</label>
                  <input type="text" class="field-input" placeholder="Cargo que está se candidatando" required />
                </div>
                <div>
                  <label class="field-label">Loja *</label>
                  <select class="field-select" required>
                    <option value="">Selecione a Loja</option>
                    <option value="junqueiropolis">Junqueirópolis/SP - Centro - Loja 01</option>
                    <option value="dracena">Dracena/SP - Centro - Loja de Dracena</option>
                  </select>
                </div>
              </div>
            </div>

            <!-- Fale sobre você -->
            <div>
              <span class="eyebrow">Fale Sobre Você</span>
              <h3 class="heading-display text-xl md:text-2xl text-[var(--color-navy)] mt-2 mb-6">Conte sua história</h3>
              <div class="divider-gold mb-6"></div>
              <div>
                <label class="field-label">Mensagem</label>
                <textarea class="field-textarea" rows="5" placeholder="Conte um pouco sobre você..."></textarea>
              </div>
            </div>

            <button type="submit" class="btn-primary w-full">Enviar Currículo</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
