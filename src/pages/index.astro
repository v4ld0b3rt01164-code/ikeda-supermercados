---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import Features from '../components/Features.astro';
import Sobre from '../components/Sobre.astro';
import Lojas from '../components/Lojas.astro';
import LojaOnline from '../components/LojaOnline.astro';
import RedesSociais from '../components/RedesSociais.astro';
---

<Layout title="Ikeda Supermercados | Da nossa família para a sua">
  <Navbar />

  <main class="min-h-screen">
    <section id="hero" class="min-h-screen w-full flex items-center bg-black relative overflow-hidden">
      <video
        autoplay
        loop
        muted
        playsinline
        class="absolute inset-0 w-full h-full object-cover hidden md:block"
      >
        <source src="/hero-pc-compressed.mp4" type="video/mp4" />
      </video>

      <video
        autoplay
        loop
        muted
        playsinline
        class="absolute inset-0 w-full h-full object-cover md:hidden"
      >
        <source src="/hero-mobile-compressed.mp4" type="video/mp4" />
      </video>

      <div class="absolute inset-0 bg-black/60"></div>

      <div class="w-full mx-auto relative z-10 flex flex-col items-center justify-center text-center px-6">
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-normal text-white leading-[1.1] reveal delay-100" style="font-family: 'Dancing Script', cursive;">
          Da nossa família para a sua desde 1941
        </h1>
      </div>
    </section>

    <Features />
    <Lojas variant="cream" />
    <Sobre />
    <LojaOnline />
    <RedesSociais />
  </main>

  <Footer />
</Layout>
