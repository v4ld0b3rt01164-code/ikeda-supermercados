---
const ofertas = [
  {
    nome: "Arroz 5kg",
    categoria: "Mercearia",
    preco: "R$ 24,90",
    precoOriginal: "R$ 29,90",
    imagem: "https://images.unsplash.com/photo-1586201375761-83865001e31c?w=400&h=400&fit=crop"
  },
  {
    nome: "Leite 1L",
    categoria: "Laticínios",
    preco: "R$ 4,99",
    precoOriginal: "R$ 5,99",
    imagem: "https://images.unsplash.com/photo-1563636619-e9143da7973b?w=400&h=400&fit=crop"
  },
  {
    nome: "Frango Inteiro",
    categoria: "Carnes",
    preco: "R$ 7,90/kg",
    precoOriginal: "R$ 9,90/kg",
    imagem: "https://images.unsplash.com/photo-1587593810167-a84920ea0781?w=400&h=400&fit=crop"
  },
  {
    nome: "Banana 1kg",
    categoria: "Hortifrúti",
    preco: "R$ 3,49",
    precoOriginal: "R$ 4,49",
    imagem: "https://images.unsplash.com/photo-1571771894821-ce9b6c11b08e?w=400&h=400&fit=crop"
  }
];
---

<section id="ofertas" class="min-h-screen w-full bg-bg px-6 md:px-12 py-20">
  <div class="max-w-7xl mx-auto">
    <div class="mb-12">
      <span class="text-xs font-medium text-accent uppercase tracking-[3px] mb-4 block">
        Ofertas da Semana
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-text mb-2">
        Promoções imperdíveis
      </h2>
      <p class="text-base text-gray-500">
        Aproveite nossas ofertas especiais
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {ofertas.map((produto) => (
        <div class="bg-white rounded-xl overflow-hidden shadow-[0_4px_24px_rgba(0,0,0,0.06)] hover:-translate-y-1 hover:shadow-[0_8px_32px_rgba(0,0,0,0.1)] transition-all duration-300">
          <div class="h-48 bg-surface flex items-center justify-center overflow-hidden">
            <img 
              src={produto.imagem} 
              alt={produto.nome} 
              class="w-full h-full object-cover"
            />
          </div>
          
          <div class="p-6">
            <span class="text-xs font-medium text-accent uppercase">
              {produto.categoria}
            </span>
            
            <h3 class="text-lg font-semibold text-text mt-1 mb-2">
              {produto.nome}
            </h3>
            
            <div class="flex items-center justify-between mb-4">
              <span class="text-2xl font-bold text-success">
                {produto.preco}
              </span>
              <span class="text-base text-gray-400 line-through">
                {produto.precoOriginal}
              </span>
            </div>

            <button class="w-full py-3 bg-accent text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors duration-200">
              Adicionar
            </button>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
