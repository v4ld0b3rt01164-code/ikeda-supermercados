    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
      <!-- Marca -->
      <div class="lg:pr-6">
        <img src="/images/logo-3d.png" alt="Ikeda Supermercados" class="h-14 w-auto mb-5 brightness-0 invert" />
        <p class="text-sm text-white/60 leading-relaxed">
          Da nossa família para a sua desde 1941. Qualidade, tradição e dedicação em cada compra.
        </p>
      </div>

      <!-- Links rápidos -->
      <div>
        <h4 class="text-xs font-bold text-[var(--color-gold)] uppercase tracking-[0.2em] mb-5">Navegação</h4>
