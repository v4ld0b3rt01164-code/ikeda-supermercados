---

<section id="sobre" class="min-h-screen w-full flex items-center bg-bg px-6 md:px-12">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col justify-center">
      <span class="text-xs font-medium text-accent uppercase tracking-[3px] mb-4">
        Nossa História
      </span>
      
      <h2 class="text-3xl md:text-4xl font-bold text-text leading-tight mb-6">
        Da nossa família<br />para a sua
      </h2>
      
      <p class="text-base text-gray-500 leading-[1.7] mb-8 max-w-lg">
        Fundada por Jorge Ikeda, imigrante japonês, a Ikeda Supermercados mantém viva a tradição de oferecer produtos frescos e de qualidade. Com mais de 85 anos de história, somos parte da vida das famílias da região.
      </p>
      
      <div class="flex gap-12">
        <div>
          <span class="block text-3xl md:text-4xl font-bold text-text">85+</span>
          <span class="text-sm text-gray-500">Anos</span>
        </div>
        <div>
          <span class="block text-3xl md:text-4xl font-bold text-text">2</span>
          <span class="text-sm text-gray-500">Lojas</span>
        </div>
        <div>
          <span class="block text-3xl md:text-4xl font-bold text-text">3</span>
          <span class="text-sm text-gray-500">Gerações</span>
        </div>
      </div>
    </div>
    
    <div class="flex items-center justify-center">
      <div class="w-full aspect-square md:aspect-[4/5] bg-surface rounded-xl overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&h=1000&fit=crop" 
          alt="História Ikeda" 
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
