---
---

<section id="sobre" class="py-24 w-full bg-bg px-6 md:px-12">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col justify-center reveal-left">
      <span class="text-xs font-bold text-primary uppercase tracking-[3px] mb-4">
        Nossa História
      </span>
      
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-tight mb-6">
        Da nossa família<br />para a sua
      </h2>
      
      <p class="text-base md:text-lg text-gray-600 leading-relaxed mb-8 max-w-lg">
        Fundada por Jorge Ikeda, imigrante japonês, a Ikeda Supermercados mantém viva a tradição de oferecer produtos frescos e de qualidade. Com mais de 85 anos de história, somos parte da vida das famílias da região.
      </p>
      
      <div class="flex flex-wrap gap-8 md:gap-12">
        <div class="reveal-bounce delay-100">
          <span class="block text-4xl md:text-5xl font-bold text-primary">85+</span>
          <span class="text-sm text-gray-500 font-medium">Anos</span>
        </div>
        <div class="reveal-bounce delay-200">
          <span class="block text-4xl md:text-5xl font-bold text-secondary">2</span>
          <span class="text-sm text-gray-500 font-medium">Lojas</span>
        </div>
        <div class="reveal-bounce delay-300">
          <span class="block text-4xl md:text-5xl font-bold text-primary">3</span>
          <span class="text-sm text-gray-500 font-medium">Gerações</span>
        </div>
      </div>
    </div>
    
    <div class="flex items-center justify-center reveal-right">
      <div class="w-full aspect-square lg:aspect-[4/5] card-highlighted overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=800&h=1000&fit=crop" 
          alt="História Ikeda" 
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
