---
---

<section id="sobre" class="py-20 md:py-28 w-full bg-cream px-6 md:px-12">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 md:gap-20 w-full max-w-7xl mx-auto items-center">
    <!-- Texto -->
    <div class="flex flex-col justify-center reveal-left order-2 lg:order-1">
      <span class="eyebrow mb-4">Nossa História</span>
      <h2 class="heading-display text-3xl md:text-4xl lg:text-5xl text-[var(--color-navy)] mb-6 text-balance">
        Da nossa família<br />para a sua
      </h2>
      <div class="divider-gold mb-6"></div>
      <p class="text-base md:text-lg text-[var(--color-muted)] leading-relaxed mb-8 max-w-lg">
        Fundada por Jorge Ikeda, imigrante japonês, a Ikeda Supermercados mantém viva a tradição de oferecer produtos frescos e de qualidade. Com mais de 85 anos de história, somos parte da vida das famílias da região.
      </p>

      <div class="flex flex-wrap gap-10 md:gap-14 mb-9">
        <div>
          <span class="block text-4xl md:text-5xl font-extrabold text-[var(--color-navy)] tracking-tight">85<span class="text-[var(--color-gold)]">+</span></span>
          <span class="text-sm text-[var(--color-muted)] font-medium uppercase tracking-wider">Anos</span>
        </div>
        <div>
          <span class="block text-4xl md:text-5xl font-extrabold text-[var(--color-navy)] tracking-tight">2</span>
          <span class="text-sm text-[var(--color-muted)] font-medium uppercase tracking-wider">Lojas</span>
        </div>
        <div>
          <span class="block text-4xl md:text-5xl font-extrabold text-[var(--color-navy)] tracking-tight">3</span>
          <span class="text-sm text-[var(--color-muted)] font-medium uppercase tracking-wider">Gerações</span>
        </div>
      </div>

      <a href="/institucional" class="btn-primary self-start">
        Conheça Nossa História
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
      </a>
    </div>

    <!-- Imagem com moldura dourada -->
    <div class="flex items-center justify-center reveal-right order-1 lg:order-2">
      <div class="relative w-full max-w-md">
        <div class="absolute -inset-3 border border-[var(--color-gold)]/40 rounded-2xl"></div>
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
          <img
            src="/images/ikeda.jpg"
            alt="Fachada do Supermercados Ikeda"
            class="w-full h-full object-cover"
            decoding="async"
          />
        </div>
      </div>
    </div>
  </div>
</section>
