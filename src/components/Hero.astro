---
---

<section id="hero" class="min-h-screen w-full flex items-center bg-black px-6 md:px-12 pt-[100px] md:pt-[120px] relative overflow-hidden">
  <video 
    autoplay 
    loop 
    muted 
    playsinline
    class="absolute inset-0 w-full h-full object-cover"
  >
    <source src="/hero-pc-compressed.mp4" type="video/mp4" />
  </video>
  
  <div class="absolute inset-0 bg-black/60"></div>

  <div class="w-full max-w-7xl mx-auto relative z-10 flex flex-col items-center justify-center text-center">
    <div class="reveal-scale">
      <img 
        src="/images/logo-3d.png" 
        alt="Ikeda Supermercados" 
        class="h-48 md:h-64 lg:h-80 w-auto drop-shadow-2xl mb-8"
      />
    </div>
    
    <h1 class="text-4xl md:text-5xl lg:text-[64px] font-bold text-white leading-[1.1] mb-6 reveal delay-100">
      Da nossa família<br />para a sua
    </h1>
    
    <p class="text-base md:text-lg text-gray-200 leading-relaxed mb-10 max-w-lg reveal delay-200">
      Desde 1941, trazendo qualidade e tradição para as mesas das famílias de Junqueirópolis e Dracena.
    </p>
    
    <div class="flex flex-wrap gap-4 justify-center reveal delay-300">
      <a 
        href="#ofertas" 
        class="btn-secondary text-base"
      >
        Ver Ofertas
      </a>
      <a 
        href="#lojas" 
        class="px-8 py-4 bg-transparent border-2 border-white text-white text-base font-semibold rounded-xl hover:bg-white hover:text-primary transition-all duration-300"
      >
        Nossas Lojas
      </a>
    </div>
  </div>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <a href="#sobre" class="text-white/70 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
      </svg>
    </a>
  </div>
</section>
