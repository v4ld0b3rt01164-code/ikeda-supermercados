---
---

<section id="hero" class="min-h-screen w-full flex items-center bg-bg px-6 md:px-12 pt-[72px]">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col justify-center order-2 md:order-1">
      <span class="text-sm font-medium text-accent uppercase tracking-[2px] mb-4">
        Supermercados Ikeda
      </span>
      
      <h1 class="text-4xl md:text-5xl lg:text-[56px] font-bold text-text leading-[1.1] mb-6">
        Da nossa família<br />para a sua
      </h1>
      
      <p class="text-base md:text-lg text-gray-500 leading-relaxed mb-10 max-w-lg">
        Desde 1941, trazendo qualidade e tradição para as mesas das famílias de Junqueirópolis e Dracena.
      </p>
      
      <div class="flex flex-wrap gap-4">
        <a 
          href="#ofertas" 
          class="px-8 py-4 bg-accent text-white text-base font-semibold rounded-lg hover:bg-blue-700 transition-colors duration-200"
        >
          Ver Ofertas
        </a>
        <a 
          href="#lojas" 
          class="px-8 py-4 bg-transparent border-2 border-border text-text text-base font-semibold rounded-lg hover:border-accent hover:text-accent transition-colors duration-200"
        >
          Nossas Lojas
        </a>
      </div>
    </div>
    
    <div class="flex items-center justify-center order-1 md:order-2">
      <div class="w-full aspect-square md:aspect-[4/5] bg-surface rounded-xl overflow-hidden">
        <img 
          src="https://images.unsplash.com/photo-1542838132-92c53300491e?w=800&h=1000&fit=crop" 
          alt="Ikeda Supermercados" 
          class="w-full h-full object-cover"
        />
      </div>
    </div>
  </div>
</section>
