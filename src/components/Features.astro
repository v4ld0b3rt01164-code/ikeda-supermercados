---
const features = [
  {
    titulo: "Ofertas",
    descricao: "Confira nossas promoções da semana",
    href: "/ofertas",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 7h.01M7 3h5a1.99 1.99 0 011.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z"/>`
  },
  {
    titulo: "Receitas",
    descricao: "Inspirações culinárias deliciosas",
    href: "/receitas",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>`
  },
  {
    titulo: "Lojas",
    descricao: "Encontre a Ikeda mais perto de você",
    href: "/lojas",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/>`
  },
  {
    titulo: "Loja Online",
    descricao: "Faça seu pedido pelo iFood",
    href: "https://www.ifood.com.br/delivery/dracena-sp/supermercados-ikeda-centro/521de33b-9449-43be-9c61-97b76c4d78d2",
    external: true,
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z"/>`
  }
];
---

<section class="py-20 md:py-24 w-full bg-white px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-14 text-center reveal max-w-2xl mx-auto">
      <span class="eyebrow mb-4">Bem-vindo</span>
      <h2 class="heading-display text-3xl md:text-4xl lg:text-5xl text-[var(--color-navy)] mt-3">
        Diariamente com amor e dedicação
      </h2>
      <div class="divider-gold mx-auto mt-5"></div>
      <p class="text-base md:text-lg text-[var(--color-muted)] mt-5">
        Para oferecer o que há de melhor da nossa família para a sua.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((feature, index) => (
        <a
          href={feature.href}
          target={feature.external ? "_blank" : undefined}
          rel={feature.external ? "noopener noreferrer" : undefined}
          class="card card-hover p-7 group flex flex-col items-center text-center reveal-scale"
          style={`animation-delay: ${index * 100}ms`}
        >
          <span class="flex items-center justify-center w-14 h-14 rounded-2xl bg-[var(--color-navy)]/5 text-[var(--color-navy)] mb-5 transition-colors duration-300 group-hover:bg-[var(--color-gold)]/15 group-hover:text-[var(--color-gold)]">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={feature.icon} />
          </span>
          <h3 class="text-lg font-bold text-[var(--color-navy)] mb-2">{feature.titulo}</h3>
          <p class="text-sm text-[var(--color-muted)] leading-relaxed">{feature.descricao}</p>
          <span class="mt-5 text-xs font-semibold text-[var(--color-gold)] uppercase tracking-wider opacity-0 -translate-y-1 transition-all duration-300 group-hover:opacity-100 group-hover:translate-y-0 inline-flex items-center gap-1">
            Acessar
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
