---
const isHome = Astro.url.pathname === '/';
---

<nav id="navbar" class:list={[
  "fixed top-0 left-0 right-0 z-50 h-[100px] md:h-[120px] flex items-center px-6 md:px-12 transition-all duration-300",
  isHome ? "bg-transparent" : "bg-white/90 backdrop-blur-lg border-b-2 border-secondary shadow-lg"
]}>
  <div class="flex items-center gap-12">
    <a href="/" class="flex items-center transition-transform duration-300 hover:scale-110">
      <img src="/images/logo.png" alt="Ikeda Supermercados" class="h-20 md:h-24 w-auto" id="nav-logo" />
    </a>
    
    <div class="hidden lg:flex items-center gap-6 ml-auto">
      <a href="/" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Início</a>
      <a href="/lojas" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Lojas</a>
      <a href="/ofertas" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Ofertas</a>
      <a href="/campanhas" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Campanhas</a>
      <a href="/receitas" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Receitas</a>
      <a href="/cartao-fidelidade" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Cartão Fidelidade</a>
      <a href="/contato" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Contato</a>
      <a href="/institucional" class:list={["text-sm font-semibold transition-colors duration-200 border-b-2 border-transparent hover:border-secondary pb-0.5", isHome ? "text-white hover:text-white" : "text-text hover:text-text"]}>Nossa História</a>
    </div>
  </div>

  <a 
    href="https://www.ifood.com.br/delivery/dracena-sp/supermercados-ikeda-centro/521de33b-9449-43be-9c61-97b76c4d78d2" 
    target="_blank" 
    rel="noopener noreferrer"
    class="hidden lg:flex ml-auto items-center gap-2 btn-secondary text-sm"
  >
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 100 4 2 2 0 000-4z" />
    </svg>
    Compre Online
    <img src="/images/ifood.png" alt="iFood" class="h-5 w-auto" />
  </a>

  <button id="menu-toggle" class="lg:hidden ml-auto p-2" aria-label="Menu">
    <svg id="menu-icon-open" class:list={["w-7 h-7", isHome ? "text-white" : "text-primary"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
    </svg>
    <svg id="menu-icon-close" class:list={["w-7 h-7 hidden", isHome ? "text-white" : "text-primary"]} fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>
</nav>

<div id="mobile-menu" class="fixed inset-0 z-40 bg-black/95 pt-[100px] md:pt-[120px] hidden flex-col items-center justify-center gap-6 lg:hidden">
  <a href="/" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Início</a>
  <a href="/lojas" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Lojas</a>
  <a href="/ofertas" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Ofertas</a>
  <a href="/campanhas" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Campanhas</a>
  <a href="/receitas" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Receitas</a>
  <a href="/cartao-fidelidade" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Cartão Fidelidade</a>
  <a href="/contato" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Contato</a>
  <a href="/institucional" class="text-lg font-semibold text-white hover:text-secondary transition-colors">Nossa História</a>
  <a 
    href="https://www.ifood.com.br/delivery/dracena-sp/supermercados-ikeda-centro/521de33b-9449-43be-9c61-97b76c4d78d2" 
    target="_blank" 
    rel="noopener noreferrer"
    class="btn-secondary text-base mt-4"
  >
    Compre Online
  </a>
</div>

<script is:inline>
  const isHomePage = window.location.pathname === '/';
  
  if (isHomePage) {
    const navbar = document.getElementById('navbar');
    const navLogo = document.getElementById('nav-logo');
    const links = navbar?.querySelectorAll('.hidden.lg\\:flex a');
    const menuToggle = document.getElementById('menu-toggle');
    const menuIconOpen = document.getElementById('menu-icon-open');
    const menuIconClose = document.getElementById('menu-icon-close');

    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        navbar?.classList.remove('bg-transparent');
        navbar?.classList.add('bg-white/90', 'backdrop-blur-lg', 'border-b-2', 'border-secondary', 'shadow-lg');
        links?.forEach(link => {
          link.classList.remove('text-white');
          link.classList.add('text-text');
        });
        menuIconOpen?.classList.remove('text-white');
        menuIconOpen?.classList.add('text-primary');
        menuIconClose?.classList.remove('text-white');
        menuIconClose?.classList.add('text-primary');
      } else {
        navbar?.classList.add('bg-transparent');
        navbar?.classList.remove('bg-white/90', 'backdrop-blur-lg', 'border-b-2', 'border-secondary', 'shadow-lg');
        links?.forEach(link => {
          link.classList.remove('text-text');
          link.classList.add('text-white');
        });
        menuIconOpen?.classList.add('text-white');
        menuIconOpen?.classList.remove('text-primary');
        menuIconClose?.classList.add('text-white');
        menuIconClose?.classList.remove('text-primary');
      }
    });
  }

  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.contains('flex');
    if (isOpen) {
      menu?.classList.add('hidden');
      menu?.classList.remove('flex');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
    } else {
      menu?.classList.remove('hidden');
      menu?.classList.add('flex');
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
    }
  });
</script>
