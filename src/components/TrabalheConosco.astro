---
---

<section id="trabalhe" class="py-24 w-full bg-gradient-to-br from-secondary via-yellow-400 to-yellow-500 px-6 md:px-12 relative overflow-hidden">
  <div class="absolute inset-0 opacity-20">
    <div class="absolute top-10 left-10 w-72 h-72 bg-primary rounded-full blur-3xl float-animation"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-white rounded-full blur-3xl float-animation" style="animation-delay: 1s;"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-16 w-full max-w-7xl mx-auto relative z-10">
    <div class="flex flex-col justify-center reveal-left">
      <span class="text-xs font-bold text-primary uppercase tracking-[3px] mb-4">
        Trabalhe Conosco
      </span>
      
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text leading-tight mb-6">
        Faça parte da<br />nossa equipe
      </h2>
      
      <p class="text-base md:text-lg text-gray-700 leading-relaxed mb-8">
        A Ikeda Supermercados está sempre em busca de pessoas talentosas e comprometidas. Envie seu currículo e venha fazer parte da nossa história!
      </p>

      <div class="grid grid-cols-2 gap-4 mb-8">
        <div class="bg-white/50 backdrop-blur-sm rounded-xl p-4 text-center">
          <span class="text-3xl block mb-2">🤝</span>
          <span class="text-sm text-text font-medium">Ambiente Acolhedor</span>
        </div>
        <div class="bg-white/50 backdrop-blur-sm rounded-xl p-4 text-center">
          <span class="text-3xl block mb-2">📈</span>
          <span class="text-sm text-text font-medium">Crescimento</span>
        </div>
        <div class="bg-white/50 backdrop-blur-sm rounded-xl p-4 text-center">
          <span class="text-3xl block mb-2">🎓</span>
          <span class="text-sm text-text font-medium">Capacitação</span>
        </div>
        <div class="bg-white/50 backdrop-blur-sm rounded-xl p-4 text-center">
          <span class="text-3xl block mb-2">💪</span>
          <span class="text-sm text-text font-medium">Benefícios</span>
        </div>
      </div>
    </div>
    
    <div class="flex items-center justify-center reveal-right">
      <div class="w-full card-highlighted p-8 bg-white">
        <h3 class="text-2xl font-bold text-text mb-6 text-center">Envie seu Currículo</h3>
        
        <form class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Nome Completo</label>
            <input 
              type="text" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="Seu nome"
            />
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Email</label>
            <input 
              type="email" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="seu@email.com"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-text mb-2">Telefone</label>
            <input 
              type="tel" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="(00) 00000-0000"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-text mb-2">Área de Interesse</label>
            <select class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors">
              <option>Selecione</option>
              <option>Reposição</option>
              <option>Caixa</option>
              <option>Padaria</option>
              <option>Açougue</option>
              <option>Hortifrúti</option>
              <option>Administrativo</option>
            </select>
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Mensagem (Opcional)</label>
            <textarea 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors resize-y h-24"
              placeholder="Conte um pouco sobre você..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full btn-primary text-base"
          >
            📤 Enviar Currículo
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
