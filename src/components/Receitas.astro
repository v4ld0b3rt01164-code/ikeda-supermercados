---
interface Props {
  variant?: 'light' | 'cream';
}
const { variant = 'cream' } = Astro.props;

const receitas = [
  {
    nome: "Sushi Caseiro",
    categoria: "Japonesa",
    tempo: "45 min",
    descricao: "Arroz temperado com peixe fresco e vegetais selecionados",
    imagem: "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=600&h=500&fit=crop"
  },
  {
    nome: "Frango Xadrez",
    categoria: "Oriental",
    tempo: "30 min",
    descricao: "Frango com legumes crocantes e molho especial da casa",
    imagem: "https://images.unsplash.com/photo-1603133872878-684f208fb84b?w=600&h=500&fit=crop"
  },
  {
    nome: "Temaki de Salmão",
    categoria: "Japonesa",
    tempo: "20 min",
    descricao: "Cones de alga recheados com salmão fresco e cream cheese",
    imagem: "https://images.unsplash.com/photo-1579584425555-c3ce17fd4351?w=600&h=500&fit=crop"
  }
];
---

<section id="receitas" class:list={["py-20 md:py-28 w-full px-6 md:px-12", variant === 'cream' ? 'bg-cream' : 'bg-white']}>
  <div class="max-w-7xl mx-auto">
    <div class="mb-14 text-center reveal max-w-2xl mx-auto">
      <span class="eyebrow mb-4">Receitas</span>
      <h2 class="heading-display text-3xl md:text-4xl lg:text-5xl text-[var(--color-navy)] mt-3">
        Inspirações culinárias
      </h2>
      <div class="divider-gold mx-auto mt-5"></div>
      <p class="text-base md:text-lg text-[var(--color-muted)] mt-5">
        Receitas fáceis com ingredientes frescos
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {receitas.map((receita, index) => (
        <article
          class="card card-hover overflow-hidden group"
          style={`animation-delay: ${index * 120}ms`}
        >
          <div class="h-60 overflow-hidden relative">
            <img
              src={receita.imagem}
              alt={receita.nome}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
            />
            <span class="absolute top-4 right-4 px-3 py-1.5 bg-white/95 backdrop-blur text-[var(--color-navy)] text-xs font-semibold rounded-full shadow-sm flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-[var(--color-gold)]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" stroke-width="1.8"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M12 7v5l3 2"/></svg>
              {receita.tempo}
            </span>
          </div>

          <div class="p-7">
            <span class="eyebrow text-[10px]">{receita.categoria}</span>
            <h3 class="text-xl font-bold text-[var(--color-navy)] mt-2 mb-3 leading-tight">
              {receita.nome}
            </h3>
            <p class="text-sm text-[var(--color-muted)] leading-relaxed mb-5">
              {receita.descricao}
            </p>
            <a href="/receitas" class="text-sm font-semibold text-[var(--color-navy)] hover:text-[var(--color-gold)] transition-colors inline-flex items-center gap-1.5 group-link">
              Ver receita
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
