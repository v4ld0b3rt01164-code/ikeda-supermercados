---
const receitas = [
  {
    nome: "Sushi Caseiro",
    categoria: "Japonesa",
    tempo: "45 min",
    descricao: "Arroz temperado com peixe fresco e vegetais selecionados",
    imagem: "https://images.unsplash.com/photo-1579871494447-9811cf80d66c?w=600&h=500&fit=crop"
  },
  {
    nome: "Frango Xadrez",
    categoria: "Main Course",
    tempo: "30 min",
    descricao: "Frango com legumes crocantes e molho especial da casa",
    imagem: "https://images.unsplash.com/photo-1603133872878-684f208fb84b?w=600&h=500&fit=crop"
  },
  {
    nome: "Temaki de Salmão",
    categoria: "Japonesa",
    tempo: "20 min",
    descricao: "Cones de alga recheados com salmão fresco e cream cheese",
    imagem: "https://images.unsplash.com/photo-1579584425555-c3ce17fd4351?w=600&h=500&fit=crop"
  }
];
---

<section id="receitas" class="py-24 w-full bg-gradient-to-br from-surface to-white px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 text-center reveal">
      <span class="text-xs font-bold text-primary uppercase tracking-[3px] mb-4 block">
        Receitas
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">
        Inspirações culinárias
      </h2>
      <p class="text-base md:text-lg text-gray-600">
        Receitas fáceis com ingredientes frescos
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {receitas.map((receita, index) => (
        <div 
          class="card-highlighted overflow-hidden group"
          style={`animation-delay: ${index * 200}ms`}
        >
          <div class="h-64 overflow-hidden relative">
            <img 
              src={receita.imagem} 
              alt={receita.nome} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <span class="absolute top-4 right-4 px-4 py-2 bg-secondary text-text text-xs font-bold rounded-full shadow-lg">
              ⏱️ {receita.tempo}
            </span>
          </div>
          
          <div class="p-6">
            <span class="text-xs font-bold text-primary uppercase">
              {receita.categoria}
            </span>
            
            <h3 class="text-xl font-bold text-text mt-2 mb-3 leading-tight">
              {receita.nome}
            </h3>
            
            <p class="text-sm text-gray-600 leading-relaxed mb-4">
              {receita.descricao}
            </p>

            <a href="#" class="text-sm font-bold text-primary hover:text-secondary transition-colors inline-flex items-center gap-1">
              Ver receita →
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
