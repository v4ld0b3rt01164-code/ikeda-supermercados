---

<section id="contato" class="py-24 w-full bg-bg px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 text-center reveal">
      <span class="text-xs font-bold text-primary uppercase tracking-[3px] mb-4 block">
        Contato
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-text mb-4">
        Fale Conosco
      </h2>
      <p class="text-base md:text-lg text-gray-600">
        Estamos prontos para atender você
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
      <div class="card-highlighted p-8 reveal-left">
        <h3 class="text-2xl font-bold text-text mb-6">Envie uma Mensagem</h3>
        
        <form class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Nome</label>
            <input 
              type="text" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="Seu nome"
            />
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Email</label>
            <input 
              type="email" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="seu@email.com"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-text mb-2">Telefone</label>
            <input 
              type="tel" 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors"
              placeholder="(00) 00000-0000"
            />
          </div>
          
          <div>
            <label class="block text-sm font-semibold text-text mb-2">Mensagem</label>
            <textarea 
              class="w-full px-4 py-3 bg-surface border-2 border-secondary rounded-xl text-text focus:outline-none focus:border-primary transition-colors resize-y h-32"
              placeholder="Sua mensagem..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full btn-primary text-base"
          >
            📨 Enviar Mensagem
          </button>
        </form>
      </div>

      <div class="space-y-6 reveal-right">
        <div class="card-highlighted p-8 text-center bg-gradient-to-br from-whatsapp/10 to-whatsapp/5 border-whatsapp/30">
          <span class="text-5xl block mb-4">📱</span>
          <h3 class="text-2xl font-bold text-text mb-2">WhatsApp</h3>
          <p class="text-base text-gray-600 mb-4">Fale conosco pelo WhatsApp</p>
          <span class="block text-xl font-bold text-whatsapp mb-6">+55 18 99737-4186</span>
          <a 
            href="https://wa.me/5518997374186"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex px-8 py-4 bg-whatsapp text-white text-base font-bold rounded-xl hover:bg-[#128c7e] transition-all duration-300 hover:scale-105"
          >
            Abrir WhatsApp
          </a>
        </div>

        <div class="card-highlighted p-8">
          <h3 class="text-xl font-bold text-text mb-4">📍 Nossas Lojas</h3>
          <div class="space-y-4">
            <div>
              <span class="font-semibold text-primary">Junqueirópolis</span>
              <p class="text-sm text-gray-600">Rua Rui Barbosa, 481</p>
              <p class="text-sm text-gray-600">(18) 3841-1326</p>
            </div>
            <div>
              <span class="font-semibold text-primary">Dracena</span>
              <p class="text-sm text-gray-600">Rua Messias Ferreira da Palma, 266</p>
              <p class="text-sm text-gray-600">(18) 3822-3272</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<footer class="py-12 bg-primary text-white px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8 mb-8">
      <div>
        <img src="/images/logo-3d.png" alt="Ikeda Supermercados" class="h-16 w-auto mb-4" />
        <p class="text-sm text-blue-200">Da nossa família para a sua desde 1941.</p>
      </div>
      
      <div>
        <h4 class="font-bold text-secondary mb-4">Links Rápidos</h4>
        <ul class="space-y-2 text-sm text-blue-200">
          <li><a href="#sobre" class="hover:text-white transition-colors">Institucional</a></li>
          <li><a href="#lojas" class="hover:text-white transition-colors">Nossas Lojas</a></li>
          <li><a href="#ofertas" class="hover:text-white transition-colors">Ofertas</a></li>
          <li><a href="#receitas" class="hover:text-white transition-colors">Receitas</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="font-bold text-secondary mb-4">Serviços</h4>
        <ul class="space-y-2 text-sm text-blue-200">
          <li><a href="#cartao" class="hover:text-white transition-colors">Cartão Fidelidade</a></li>
          <li><a href="#trabalhe" class="hover:text-white transition-colors">Trabalhe Conosco</a></li>
          <li><a href="#contato" class="hover:text-white transition-colors">Contato</a></li>
          <li><a href="https://www.ifood.com.br/delivery/dracena-sp/supermercados-ikeda-centro/521de33b-9449-43be-9c61-97b76c4d78d2" target="_blank" class="hover:text-white transition-colors">Loja Online</a></li>
        </ul>
      </div>
      
      <div>
        <h4 class="font-bold text-secondary mb-4">Contato</h4>
        <ul class="space-y-2 text-sm text-blue-200">
          <li>📍 Junqueirópolis: (18) 3841-1326</li>
          <li>📍 Dracena: (18) 3822-3272</li>
          <li>📱 WhatsApp: (18) 99737-4186</li>
        </ul>
      </div>
    </div>

    <div class="border-t border-blue-600 pt-8 text-center">
      <p class="text-sm text-blue-200">
        © 2026 Ikeda Supermercados. Todos os direitos reservados.
      </p>
    </div>
  </div>
</footer>

