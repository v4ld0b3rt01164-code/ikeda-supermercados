---
---

<section id="contato" class="py-24 w-full bg-cream px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="mb-16 text-center reveal">
      <span class="eyebrow mb-4">Contato</span>
      <h2 class="heading-display text-3xl md:text-4xl lg:text-5xl text-[var(--color-navy)] mt-3">
        Fale Conosco
      </h2>
      <div class="divider-gold mx-auto mt-5"></div>
      <p class="text-base md:text-lg text-[var(--color-muted)] mt-5">
        Estamos prontos para atender você
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
      <div class="card p-8 reveal-left">
        <h3 class="heading-display text-2xl text-[var(--color-navy)] mb-6">Envie uma Mensagem</h3>

        <form class="space-y-5">
          <div>
            <label class="field-label">Nome</label>
            <input
              type="text"
              class="field-input"
              placeholder="Seu nome"
            />
          </div>

          <div>
            <label class="field-label">Email</label>
            <input
              type="email"
              class="field-input"
              placeholder="seu@email.com"
            />
          </div>

          <div>
            <label class="field-label">Telefone</label>
            <input
              type="tel"
              class="field-input"
              placeholder="(00) 00000-0000"
            />
          </div>

          <div>
            <label class="field-label">Mensagem</label>
            <textarea
              class="field-textarea h-32"
              placeholder="Sua mensagem..."
            ></textarea>
          </div>

          <button
            type="submit"
            class="btn-primary w-full"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Enviar Mensagem
          </button>
        </form>
      </div>

      <div class="space-y-6 reveal-right">
        <div class="card p-8 text-center bg-gradient-to-br from-[var(--color-whatsapp)]/10 to-[var(--color-whatsapp)]/5 border border-[var(--color-whatsapp)]/30">
          <span class="inline-flex items-center justify-center w-14 h-14 rounded-full bg-[var(--color-whatsapp)]/15 text-[var(--color-whatsapp)] mb-4">
            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </span>
          <h3 class="heading-display text-2xl text-[var(--color-navy)] mb-2">WhatsApp</h3>
          <p class="text-base text-[var(--color-muted)] mb-4">Fale conosco pelo WhatsApp</p>
          <span class="block text-xl font-bold text-[var(--color-whatsapp)] mb-6">+55 18 99737-4186</span>
          <a
            href="https://wa.me/5518997374186"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex px-8 py-4 bg-[var(--color-whatsapp)] text-white text-base font-bold rounded-xl hover:bg-[#128c7e] transition-all duration-300 hover:scale-105"
          >
            Abrir WhatsApp
          </a>
        </div>

        <div class="card p-8">
          <h3 class="heading-display text-xl text-[var(--color-navy)] mb-4">Nossas Lojas</h3>
          <div class="space-y-4">
            <div>
              <span class="block text-sm font-bold text-[var(--color-navy)]">Junqueirópolis</span>
              <p class="text-sm text-[var(--color-muted)]">Rua Rui Barbosa, 481</p>
              <p class="text-sm text-[var(--color-muted)]">(18) 3841-1326</p>
            </div>
            <div>
              <span class="block text-sm font-bold text-[var(--color-navy)]">Dracena</span>
              <p class="text-sm text-[var(--color-muted)]">Rua Messias Ferreira da Palma, 266</p>
              <p class="text-sm text-[var(--color-muted)]">(18) 3822-3272</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
